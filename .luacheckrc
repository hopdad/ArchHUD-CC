-- Regenerate the long lists:
--   exports: grep -E '\-\-export:' src/ArchHUD.lua | grep -oE '^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*'
--   state:   sed -n '78,189p' src/requires/globals.lua | grep -oE '^[[:space:]]+[A-Za-z_][A-Za-z0-9_]* ='
