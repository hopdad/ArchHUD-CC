-- luacheck configuration for ArchHUD-CC
-- Scoped to the hand-written, shipped flight/HUD logic. DU is global-heavy by
-- design (settings must be global for the databank save/load system, and the
-- minified build collapses everything into one scope), so the global lists below
-- are intentionally large. Regeneration commands are at the bottom of this file.

std = "lua53"
max_line_length = false
codes = true

-- Exclude dev-only scaffolding so the signal stays high:
--   src/du, src/builtin  : DU API stubs / vendored emulator (not shipped logic)
--   du_prologue, slots    : global-wiring files (would clash with read_globals)
--   scripts, tests, board : build tooling, tests, generated board output
exclude_files = {
    "src/du",
    "src/builtin",
    "src/du_prologue.lua",
    "src/slots.lua",
    "scripts",
    "tests",
    "board",
}

ignore = {
    "212", -- unused argument (DI constructors legitimately take many params)
    "213", -- unused loop variable
    "611", "612", "613", "614", -- whitespace
    "631", -- line too long (handled by max_line_length = false)
}

-- DU runtime API, element classes and slot globals: read-only in the linted
-- files (provided by the game and by the excluded slots/prologue wiring).
read_globals = {
    -- namespaces
    "system", "unit", "construct", "player", "library",
    "DUSystem", "DUConstruct", "DUPlayer", "System", "Construct", "Player", "Library",
    -- element classes
    "CoreUnit", "ControlUnit", "RadarPVPUnit", "RadarUnit", "AntiGravityGeneratorUnit",
    "WarpDriveUnit", "GyroUnit", "WeaponUnit", "DataBankUnit", "databank", "TelemeterUnit",
    "TransponderUnit", "VerticalBooster", "Hovercraft", "DoorUnit", "ManualSwitchUnit",
    "ManualButtonUnit", "ForceFieldUnit", "AtmoFuelContainer", "SpaceFuelContainer",
    "RocketFuelContainer", "ShieldGeneratorUnit", "BaseShieldGeneratorUnit", "ScreenUnit",
    "Element", "Engine", "FueledEngine", "AtmosphericEngine", "SpaceEngine", "RocketEngine",
    "Airfoil", "Container", "ItemContainer", "LandingGearUnit", "LightUnit", "CounterUnit",
    "EmitterUnit", "ReceiverUnit", "DetectionZoneUnit", "LaserDetectorUnit",
    "LaserEmitterUnit", "PressureTileUnit", "IndustryUnit", "Firework",
    -- DU-provided helpers
    "json", "vec3", "epsilon", "L_TEXT", "_autoconf",
    -- slot globals (assigned in src/slots.lua, read here)
    "antigrav",
    "atmofueltank",
    "atmofueltank_size",
    "core",
    "dbHud",
    "door",
    "forcefield",
    "gyro",
    "hover",
    "radar",
    "radar_1",
    "radar_2",
    "radar_size",
    "rocketfueltank",
    "rocketfueltank_size",
    "screenHud",
    "screen_1",
    "screen_2",
    "shield",
    "spacefueltank",
    "spacefueltank_size",
    "switch",
    "telemeter",
    "transponder",
    "vBooster",
    "warpdrive",
    "weapon",
    "weapon_size",
}

